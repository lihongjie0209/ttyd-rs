{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "lib": ["ES2020", "DOM"],
        "skipLibCheck": true
    },
    "include": ["src/**/*.ts"]
}
